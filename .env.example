# Composer Keys
COMPOSER_KEY_ID='your_composer_key_id_here'
COMPOSER_SECRET='your_composer_secret_here'

# Your Composer Account UUIDs (comma separated if you have more than one)
ACCOUNT_UUIDS='your_account_uuid_1,your_account_uuid_2'

# Alpaca Keys (Paper or Live, doesn't matter for data)
ALPACA_KEY='your_alpaca_key_here'
ALPACA_SECRET='your_alpaca_secret_here'

# Discord Webhook (Where you want your alerts to go)
DISCORD_WEBHOOK_URL='https://discord.com/api/webhooks/your_webhook_url'

# Master Safety Switch
LIVE_EXECUTION='False'

# Environment Thresholds
VIX_LOW_THRESHOLD='15.0'
VIX_HIGH_THRESHOLD='25.0'
EXECUTION_START_TIME='09:30'
